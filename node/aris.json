    {
        "id": "158d3a6865d9a631",
        "type": "function",
        "z": "2f7853bde0a29107",
        "name": "function temperatura",
        "func": "let temp = Number(msg.payload);\n\nif (isNaN(temp)) {\n    msg.payload = \"Sem dados ainda\";\n    return msg;\n}\n\nif (temp > 30) {\n    msg.payload = \"Temperatura Alta\";\n}\nelse if (temp < 20) {\n    msg.payload = \"Temperatura Baixa\";\n}\nelse {\n    msg.payload = \"Temperatura Ideal\";\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
