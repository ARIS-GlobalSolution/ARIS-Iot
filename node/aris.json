        "name": "Salvar dados de temperatura",
        "func": "let temp = parseFloat(msg.payload);\n\nif (isNaN(temp)) {\n    return null;\n}\n\nmsg.topic = \"INSERT INTO aris (temperatura) VALUES (?)\";\nmsg.payload = [temp];\n\nreturn msg;",
