        "type": "function",
        "z": "2f7853bde0a29107",
        "name": "function nivel",
        "func": "let nivel = Number(msg.payload);\n\nif (isNaN(nivel)) {\n    msg.payload = \"Sem dados ainda\";\n    return msg;\n}\n\nif (nivel > 20) {\n    msg.payload = \"Reservatorio Baixo\";\n}\nelse {\n    msg.payload = \"Reservatorio OK\";\n}\n\nreturn msg;",
